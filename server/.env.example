# Server
PORT=5000
BASE_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://neuronflow:neuronflow@localhost:5432/neuronflow
# For dev: sqlite:///./prisma/dev.db

# Auth
JWT_SECRET=neuronflow-dev-jwt-secret-change-in-production

# Redis (optional, for session caching)
REDIS_URL=redis://localhost:6379

# AI Integrations (placeholder for future)
OPENAI_API_KEY=
VAPI_API_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
ELEVENLABS_API_KEY=
N8N_WEBHOOK_URL=

# Payments
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# Frontend (for CORS and OAuth callbacks)
FRONTEND_URL=http://localhost:5173